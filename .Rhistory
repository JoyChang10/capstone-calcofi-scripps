report$ok <<- FALSE
report[[name]] <<- rows
report[[paste0(name, "_count")]] <<- length(rows)
} else {
report[[name]] <<- integer(0)
report[[paste0(name, "_count")]] <<- 0L
}
}
# ----------------------------
# 1) Required raw columns
# ----------------------------
required_raw <- c("unique.code", "latitude", "longitude", "year", "season")
missing_cols <- setdiff(required_raw, names(df_raw))
report$missing_columns <- missing_cols
report$missing_columns_count <- length(missing_cols)
if (length(missing_cols) > 0) {
# Can't safely proceed with row-level checks if required columns are missing
report$ok <- FALSE
if (verbose) {
message("❌ RAW validation FAILED (missing required columns): ",
paste(missing_cols, collapse = ", "))
}
return(report)
}
# ----------------------------
# 2) Type coercion + optional season normalization
# ----------------------------
df2 <- df_raw %>%
mutate(
latitude  = suppressWarnings(as.numeric(latitude)),
longitude = suppressWarnings(as.numeric(longitude)),
year      = suppressWarnings(as.integer(year)),
season    = trimws(as.character(season))
)
if (normalize_season) {
df2 <- df2 %>% mutate(season = tools::toTitleCase(tolower(season)))
}
# ----------------------------
# 3) NA checks (ALL rows)
# ----------------------------
add_rows("na_unique_code_rows", which(is.na(df2$unique.code)))
add_rows("na_latitude_rows",    which(is.na(df2$latitude)))
add_rows("na_longitude_rows",   which(is.na(df2$longitude)))
add_rows("na_year_rows",        which(is.na(df2$year)))
add_rows("na_season_rows",      which(is.na(df2$season) | df2$season == ""))
# ----------------------------
# 4) Duplicate unique_code (ALL involved rows, includes first occurrence)
# ----------------------------
dup_uc_rows <- which(
duplicated(df2$unique.code) | duplicated(df2$unique.code, fromLast = TRUE)
)
add_rows("duplicate_unique_code_rows", dup_uc_rows)
# Optional: also provide which unique_code values are duplicated (helps debugging)
if (length(dup_uc_rows) > 0) {
dup_values <- df2$unique.code[dup_uc_rows]
report$duplicate_unique_code_values <- sort(unique(dup_values))
report$duplicate_unique_code_values_count <- length(report$duplicate_unique_code_values)
} else {
report$duplicate_unique_code_values <- character(0)
report$duplicate_unique_code_values_count <- 0L
}
# ----------------------------
# 5) Season validity (ALL invalid rows)
# ----------------------------
bad_season_rows <- which(!(df2$season %in% valid_seasons))
# If season is NA/empty, it's already flagged above, but we still list it here if you want strictly invalid:
bad_season_rows <- setdiff(bad_season_rows, report$na_season_rows)
add_rows("invalid_season_rows", bad_season_rows)
# Optional: invalid season values list
if (length(bad_season_rows) > 0) {
report$invalid_season_values <- sort(unique(df2$season[bad_season_rows]))
report$invalid_season_values_count <- length(report$invalid_season_values)
} else {
report$invalid_season_values <- character(0)
report$invalid_season_values_count <- 0L
}
# ----------------------------
# 6) Global lat/lon sanity (ALL invalid rows)
# ----------------------------
add_rows("lat_global_range_rows", which(df2$latitude < -90 | df2$latitude > 90))
add_rows("lon_global_range_rows", which(df2$longitude < -180 | df2$longitude > 180))
# ----------------------------
# 7) CalCOFI bbox checks (ALL invalid rows)
# ----------------------------
add_rows("lat_bbox_rows", which(df2$latitude < bbox["lat_min"] | df2$latitude > bbox["lat_max"]))
add_rows("lon_bbox_rows", which(df2$longitude < bbox["lon_min"] | df2$longitude > bbox["lon_max"]))
# ----------------------------
# 8) Year range checks (ALL invalid rows)
# ----------------------------
add_rows("year_range_rows", which(df2$year < year_min | df2$year > year_max))
# ----------------------------
# Summary
# ----------------------------
if (verbose) {
if (isTRUE(report$ok)) {
message("✅ RAW validation passed (wide dataset). Rows checked: ", report$n_rows)
} else {
message("❌ RAW validation FAILED. Rows checked: ", report$n_rows)
# Print every error type with counts + row numbers
# (skip missing_columns which is not row-based)
row_keys <- names(report)[grepl("_rows$", names(report))]
for (k in row_keys) {
cnt <- report[[paste0(k, "_count")]]
if (!is.null(cnt) && cnt > 0) {
message("  - ", k, " (", cnt, "): ", paste(report[[k]], collapse = ", "))
}
}
if (report$missing_columns_count > 0) {
message("  - missing_columns (", report$missing_columns_count, "): ",
paste(report$missing_columns, collapse = ", "))
}
}
}
report
}
