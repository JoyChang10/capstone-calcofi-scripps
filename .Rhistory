# This script handles headless authentication for Google Drive API
library(googledrive)
# Uses the service account key path stored in .Renviron to
# establish a non-interactive (headless) connection
authenticate_drive <- function() {
key_path <- Sys.getenv("GDRIVE_AUTH_PATH")
if (key_path == "") {
stop("Error: GDRIVE_AUTH_PATH not found in .Renviron. Check your setup!")
}
drive_auth(path = key_path)
message("Successfully authenticated with Google Drive via Service Account.")
}
# Test the connection (comment this out when not testing)
authenticate_drive()
drive_find(n_max = 3)
drive_user()
drive_find(q = "sharedWithMe = true")
drive_find(q = "sharedWithMe = true")
drive_ls(as_id("https://drive.google.com/drive/u/0/folders/1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-?lfhs=2"))
drive_ls(as_id("1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-"))
drive_find(type = "folder", q = "sharedWithMe = true")
my_folder <- drive_get(id = "1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-")
drive_ls(my_folder)
drive_shared_drives()
drive_ls(as_id("1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-"), crossword = FALSE)
drive_get(id = "1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-", shared_drive = TRUE)
