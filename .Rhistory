# This script handles headless authentication for Google Drive API
library(googledrive)
# Uses the service account key path stored in .Renviron to
# establish a non-interactive (headless) connection
authenticate_drive <- function() {
key_path <- Sys.getenv("GDRIVE_AUTH_PATH")
if (key_path == "") {
stop("Error: GDRIVE_AUTH_PATH not found in .Renviron. Check your setup!")
}
drive_auth(path = key_path)
message("Successfully authenticated with Google Drive via Service Account.")
}
# Test the connection (comment this out when not testing)
# 1. Authenticate (Person 3 Deliverable)
authenticate_drive()
# 2. Get the folder object using the ID and shared_drive flag (Already verified)
test_folder <- drive_get(id = "1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-", shared_drive = TRUE)
# 3. List the contents specifically within this folder object
# This avoids the 404 error by passing the verified folder metadata
drive_ls(test_folder)
# 2. Get the folder object using the ID and shared_drive flag (Already verified)
drive_get(id = "1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-", shared_drive = TRUE)
# This script handles headless authentication for Google Drive API
library(googledrive)
# Uses the service account key path stored in .Renviron to
# establish a non-interactive (headless) connection
authenticate_drive <- function() {
key_path <- Sys.getenv("GDRIVE_AUTH_PATH")
if (key_path == "") {
stop("Error: GDRIVE_AUTH_PATH not found in .Renviron. Check your setup!")
}
drive_auth(path = key_path)
message("Successfully authenticated with Google Drive via Service Account.")
}
# Test the connection (comment this out when not testing)
# 1. Authenticate (Person 3 Deliverable)
authenticate_drive()
# 2. Get the folder object (using the ID you verified earlier)
# Use 'shared_drive = TRUE' only here to identify the resource
test_folder <- drive_get(id = "1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-", shared_drive = TRUE)
# 3. List the contents by passing the verified ID directly
# Do NOT use 'shared_drive = TRUE' inside drive_ls; let it resolve from the ID
drive_ls(as_id(test_folder$id))
# This script handles headless authentication for Google Drive API
library(googledrive)
# Uses the service account key path stored in .Renviron to
# establish a non-interactive (headless) connection
authenticate_drive <- function() {
key_path <- Sys.getenv("GDRIVE_AUTH_PATH")
if (key_path == "") {
stop("Error: GDRIVE_AUTH_PATH not found in .Renviron. Check your setup!")
}
drive_auth(path = key_path)
message("Successfully authenticated with Google Drive via Service Account.")
}
# Test the connection (comment this out when not testing)
# 1. Authenticate (Person 3 Deliverable)
authenticate_drive()
target_folder_id <- "1i1GriH-U5h2iFIPVWQwjIHwZk8JNWzV-"
# 3. List files by searching for anything whose parent is this folder
# This bypasses the "Shared Drive Not Found" error
drive_find(q = paste0("'", target_folder_id, "' in parents"))
