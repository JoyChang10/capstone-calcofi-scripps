library(tidyverse)
library(dendextend)
library(e1071)
leukemia_data <- read_csv("leukemia_data.csv")
leukemia_data$Type <- factor(leukemia_data$Type)
table(leukemia_data$Type)
pca <- prcomp(leukemia_data[-1], scale=TRUE, center=TRUE)
pr.var=pca$sdev^2
pve=pr.var/sum(pr.var)
plot(pve, xlab="Principal Component",
ylab="Proportion of Variance Explained ", ylim=c(0,1),type='b')
plot(cumsum(pve), xlab="Principal Component ",
ylab=" Cumulative Proportion of Variance Explained ", ylim=c(0,1), type='b')
which(cumsum(pve) >= .9)[1]
pca <- prcomp(-leukemia_data[1], scale=TRUE, center=TRUE)
pca <- prcomp(leukemia_data[,-1], scale=TRUE, center=TRUE)
pr.var=pca$sdev^2
pve=pr.var/sum(pr.var)
plot(pve, xlab="Principal Component",
ylab="Proportion of Variance Explained ", ylim=c(0,1),type='b')
plot(cumsum(pve), xlab="Principal Component ",
ylab=" Cumulative Proportion of Variance Explained ", ylim=c(0,1), type='b')
which(cumsum(pve) >= .9)[1]
view(lukemia_data)
view(leukemia_data)
rainbow_colors <- rainbow(7)
plot_colors <- rainbow_colors[as.factor(leukemia_data$Type)]
plot(pca$x[,1], pca$x[,2], col=plot_colors, main = "First Two Principal Components", xlab = "PCA 1", ylab = "PCA 2")
text(pca$x[,1], pca$x[,2], labels = leukemia_data$Type, col = plot_colors, cex = .5)
rainbow_colors <- rainbow(7)
plot_colors <- rainbow_colors[as.factor(leukemia_data$Type)]
plot(pca$x[,1], pca$x[,2], col=plot_colors, main = "First Two Principal Components", xlab = "PCA 1", ylab = "PCA 2")
text(pca$x[,1], pca$x[,2], labels = leukemia_data$Type, col = plot_colors, cex = .5)
loadings_pc1 <- pca$rotation[,1]
abs_loading <- abs(loadings_pc1)
sorted_genes <- sort(abs_loading, decreasing = TRUE)
head(sorted_genes, 6)
