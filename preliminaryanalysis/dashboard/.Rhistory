set.seed(123)
leukemia_subset <- leukemia_data %>%
filter(Type %in% c("T-ALL", "TEL-AML1", "Hyperdip50"))
x <- leukemia_subset %>% select(-Type)
dist <- dist(x, method = "euclidean")
hclust <- hclust(dist, method = "complete")
dend <- as.dendrogram(hclust)
dend <- dend %>%
set("branches_k_color", k = 3) %>%
set("labels_colors", k=3) %>%
set("labels_cex", 0.5)
labels(dend) <- leukemia_subset$Type
plot(dend, horiz = TRUE, main = "Dendrogram with 3 Groups", xlab = "Height")
dend2 <- as.dendrogram(hclust)
dend2 <- dend2 %>%
set("branches_k_color", k = 5) %>%
set("labels_colors", k=5) %>%
set("labels_cex", 0.5)
labels(dend2) <- leukemia_subset$Type
plot(dend2, horiz = TRUE, main = "Dendrogram with 5 Groups", xlab = "Height")
drug <- read_csv('drug.csv',
col_names=c('ID','Age','Gender','Education','Country',
'Ethnicity','Nscore',
'Escore','Oscore','Ascore','Cscore',
'Impulsive','SS','Alcohol','Amphet','Amyl','Benzos',
'Caff','Cannabis', 'Choc','Coke','Crack','Ecstasy',
'Heroin','Ketamine','Legalh','LSD','Meth',
'Mushrooms','Nicotine','Semer','VSA'))
set.seed(123)
drug <- drug %>%
mutate(recent_nicotine_use = factor(
ifelse(Nicotine >= "CL3", "Yes", "No"),
levels = c("No", "Yes")
)) %>%
select(Age:SS, recent_nicotine_use)
test.indices <- sample(1:nrow(drug), 1000)
drug.train <- drug[test.indices,]
drug.test <- drug[-test.indices,]
svmfit=svm(recent_nicotine_use ~ ., data=drug.train, kernel="radial", cost=1, scale=FALSE)
summary(svmfit)
ypred=predict(svmfit,drug.test)
table(predict=ypred, truth=drug.test$recent_nicotine_use)
set.seed(123)
options(scipen = 999)
tune.out=tune(svm, recent_nicotine_use~.,data=drug.train,kernel="radial",
ranges=list(cost=c(0.001, 0.01, 0.1, 1, 5, 10, 100)))
summary(tune.out)
bestmod=tune.out$best.model
ypred=predict(bestmod,drug.test)
table(predict=ypred, truth=drug.test$recent_nicotine_use)
set.seed(123)
drug <- drug %>%
mutate(recent_nicotine_use = factor(
ifelse(Nicotine >= "CL3", "Yes", "No"),
levels = c("No", "Yes")
)) %>%
select(Age:SS, recent_nicotine_use)
